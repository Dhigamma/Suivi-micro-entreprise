import React, { useEffect, useState } from 'react'
import { supabase } from '../lib/supabase'
import { BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer, Cell } from 'recharts'

const MOIS = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre']

function fmtEur(v) {
  const n = parseFloat(v) || 0
  if (Math.abs(n) >= 1000) return (n/1000).toFixed(1) + ' k€'
  return n.toLocaleString('fr-FR', { style:'currency', currency:'EUR', maximumFractionDigits:0 })
}

function KpiCard({ icon, label, value, sub, color='var(--accent2)', bg='var(--bg2)' }) {
  return (
    <div style={{
      background: bg, border:'1px solid var(--border)', borderRadius:'var(--radius)',
      padding:'14px', position:'relative', overflow:'hidden'
    }}>
      <div style={{ fontSize:20, marginBottom:8 }}>{icon}</div>
      <div style={{ fontSize:17, fontWeight:600, color, fontFamily:'monospace', letterSpacing:'-.5px', marginBottom:3 }}>{value}</div>
      <div style={{ fontSize:11, color:'var(--text2)' }}>{label}</div>
      {sub && <div style={{ fontSize:10, color:'var(--text3)', marginTop:2 }}>{sub}</div>}
    </div>
  )
}

export default function Dashboard() {
  const [data, setData] = useState(null)
  const [params, setParams] = useState({ taux_horaire:40, ca_vise_mensuel:2700, taux_urssaf:0.22 })
  const [mois1, setMois1] = useState(new Date().getMonth())
  const [mois2, setMois2] = useState(new Date().getMonth() > 0 ? new Date().getMonth()-1 : 11)
  const [annee, setAnnee] = useState(new Date().getFullYear())
  const [loading, setLoading] = useState(true)

  useEffect(() => { loadData() }, [])

  async function loadData() {
    setLoading(true)
    const { data: { user } } = await supabase.auth.getUser()
    const uid = user.id

    const [tR, fR, dR, pR] = await Promise.all([
      supabase.from('taches').select('*, clients(societe)').eq('user_id', uid),
      supabase.from('factures').select('*').eq('user_id', uid),
      supabase.from('depenses').select('*').eq('user_id', uid),
      supabase.from('parametres').select('*').eq('user_id', uid).single(),
    ])

    if (pR.data) setParams(pR.data)
    setData({ taches: tR.data||[], factures: fR.data||[], depenses: dR.data||[] })
    setLoading(false)
  }

  if (loading) return <div style={{ color:'var(--text2)', textAlign:'center', padding:'3rem' }}>Chargement…</div>

  const { taches, factures, depenses } = data
  const taux = params.taux_horaire
  const caVise = params.ca_vise_mensuel
  const txU = params.taux_urssaf

  // KPIs globaux
  const totalH = taches.reduce((s,r) => s + (parseFloat(r.duree)||0), 0)
  const valH = totalH * taux
  const caFact = factures.reduce((s,r) => s + (parseFloat(r.montant)||0), 0)
  const caPaye = factures.filter(r=>r.paye).reduce((s,r) => s + (parseFloat(r.montant)||0), 0)
  const depTotal = depenses.reduce((s,r) => s + (parseFloat(r.montant)||0), 0)
  const benefice = caPaye - depTotal
  const pct = caVise > 0 ? Math.min(Math.round(valH/caVise*100), 100) : 0
  const progColor = pct >= 100 ? 'var(--accent2)' : pct >= 75 ? 'var(--orange)' : 'var(--accent2)'

  // Filtre par mois
  function filterMois(arr, m, y, dateKey='date') {
    return arr.filter(r => {
      const d = new Date(r[dateKey])
      return d.getMonth() === m && d.getFullYear() === y
    })
  }

  function kpisMois(m, y) {
    const t = filterMois(taches, m, y)
    const f = filterMois(factures, m, y)
    const d = filterMois(depenses, m, y)
    const h = t.reduce((s,r) => s+(parseFloat(r.duree)||0), 0)
    const ca = f.reduce((s,r) => s+(parseFloat(r.montant)||0), 0)
    const caP = f.filter(r=>r.paye).reduce((s,r) => s+(parseFloat(r.montant)||0), 0)
    const dep = d.reduce((s,r) => s+(parseFloat(r.montant)||0), 0)
    return { heures:h, valeur:h*taux, ca, caP, depenses:dep, benefice:caP-dep }
  }

  const k1 = kpisMois(mois1, annee)
  const k2 = kpisMois(mois2, annee)

  // Heures par client
  const clientMap = {}
  taches.forEach(r => {
    const c = r.clients?.societe || 'Inconnu'
    clientMap[c] = (clientMap[c]||0) + (parseFloat(r.duree)||0)
  })
  const chartData = Object.entries(clientMap).map(([name, heures]) => ({ name, heures }))

  // Dernières tâches
  const recentTaches = [...taches].sort((a,b) => new Date(b.date)-new Date(a.date)).slice(0,5)

  const compareRow = (label, v1, v2, fmt=fmtEur) => {
    const diff = v2 - v1
    const pct = v1 ? ((diff/Math.abs(v1))*100).toFixed(1) : '—'
    const up = diff >= 0
    return (
      <div key={label} style={{
        display:'grid', gridTemplateColumns:'1fr 1fr 1fr 80px 60px',
        gap:8, padding:'10px 0', borderBottom:'1px solid var(--border)',
        fontSize:13, alignItems:'center'
      }}>
        <span style={{ color:'var(--text2)' }}>{label}</span>
        <span style={{ fontWeight:600, color:'var(--blue)', fontFamily:'monospace' }}>{fmt(v1)}</span>
        <span style={{ fontWeight:600, color:'var(--orange)', fontFamily:'monospace' }}>{fmt(v2)}</span>
        <span style={{ fontFamily:'monospace', color: up?'var(--accent2)':'var(--red)' }}>
          {up?'+':''}{fmt(diff)}
        </span>
        <span style={{ color: up?'var(--accent2)':'var(--red)', fontSize:12 }}>
          {pct !== '—' ? (up?'▲':'▼')+Math.abs(pct)+'%' : '—'}
        </span>
      </div>
    )
  }

  return (
    <div style={{ display:'flex', flexDirection:'column', gap:14 }}>

      {/* Progression objectif */}
      <div style={{
        background:'linear-gradient(135deg,var(--bg2),#1a2235)',
        border:'1px solid var(--border)', borderRadius:'var(--radius)',
        padding:'16px 18px', position:'relative', overflow:'hidden'
      }} className="anim">
        <div style={{ position:'absolute', top:0, left:0, right:0, height:2, background:'linear-gradient(90deg,var(--accent),var(--accent2))' }}></div>
        <div style={{ display:'flex', justifyContent:'space-between', alignItems:'flex-start', marginBottom:10 }}>
          <div>
            <div style={{ fontSize:12, color:'var(--text2)' }}>🎯 Objectif CA mensuel</div>
            <div style={{ fontSize:28, fontWeight:600, fontFamily:'monospace', color:progColor, marginTop:4 }}>{pct}%</div>
          </div>
          <div style={{ textAlign:'right' }}>
            <div style={{ fontSize:11, color:'var(--text2)' }}>{totalH}h × {taux}€/h</div>
            <div style={{ fontSize:17, fontWeight:600, fontFamily:'monospace', marginTop:2 }}>{fmtEur(valH)}</div>
            <div style={{ fontSize:11, color:'var(--text2)' }}>sur {fmtEur(caVise)}</div>
          </div>
        </div>
        <div style={{ height:6, background:'var(--bg4)', borderRadius:10, overflow:'hidden' }}>
          <div style={{ height:'100%', width:pct+'%', background:'linear-gradient(90deg,var(--accent),var(--accent2))', borderRadius:10, transition:'width .8s' }}></div>
        </div>
      </div>

      {/* KPIs */}
      <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:10 }} className="anim">
        <KpiCard icon="⏱" label="Heures" value={totalH+'h'} sub={fmtEur(valH)} />
        <KpiCard icon="💳" label="CA facturé" value={fmtEur(caFact)} sub={factures.length+' factures'} color="var(--text)" />
        <KpiCard icon="✅" label="CA encaissé" value={fmtEur(caPaye)} sub={factures.filter(f=>f.paye).length+' payées'} color="var(--accent2)" />
        <KpiCard icon="⬇️" label="Dépenses" value={fmtEur(depTotal)} sub={depenses.length+' entrées'} color="var(--red)" />
        <KpiCard icon="📈" label="Bénéfice" value={fmtEur(benefice)} sub="estimé" color={benefice>=0?'var(--accent2)':'var(--red)'} />
        <KpiCard icon="🏦" label="URSSAF estimé" value={fmtEur(caPaye*txU)} sub={'Revenu net : '+fmtEur(caPaye*(1-txU))} color="var(--orange)" />
      </div>

      {/* Comparaison mois */}
      <div style={{ background:'var(--bg2)', border:'1px solid var(--border)', borderRadius:'var(--radius)', padding:'14px 16px' }} className="anim">
        <div style={{ fontSize:13, fontWeight:500, color:'var(--text2)', marginBottom:12 }}>📅 Comparaison mois / mois</div>

        {/* Sélecteurs */}
        <div style={{ display:'flex', gap:8, flexWrap:'wrap', marginBottom:14, alignItems:'center' }}>
          <select value={mois1} onChange={e=>setMois1(+e.target.value)} style={selStyle('#4a90e2')}>
            {MOIS.map((m,i) => <option key={i} value={i}>{m}</option>)}
          </select>
          <span style={{ color:'var(--text3)', fontSize:13 }}>vs</span>
          <select value={mois2} onChange={e=>setMois2(+e.target.value)} style={selStyle('var(--orange)')}>
            {MOIS.map((m,i) => <option key={i} value={i}>{m}</option>)}
          </select>
          <select value={annee} onChange={e=>setAnnee(+e.target.value)} style={selStyle('var(--text2)')}>
            {[2024,2025,2026,2027].map(y => <option key={y} value={y}>{y}</option>)}
          </select>
        </div>

        {/* En-têtes */}
        <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr 1fr 80px 60px', gap:8, marginBottom:4 }}>
          {['Indicateur', MOIS[mois1], MOIS[mois2], 'Variation', '%'].map(h => (
            <span key={h} style={{ fontSize:11, fontWeight:500, color:'var(--text3)', textTransform:'uppercase', letterSpacing:'1px' }}>{h}</span>
          ))}
        </div>

        {compareRow('Heures', k1.heures, k2.heures, v => (parseFloat(v)||0).toFixed(1)+'h')}
        {compareRow('Valeur heures', k1.valeur, k2.valeur)}
        {compareRow('CA facturé', k1.ca, k2.ca)}
        {compareRow('CA encaissé', k1.caP, k2.caP)}
        {compareRow('Dépenses', k1.depenses, k2.depenses)}
        {compareRow('Bénéfice', k1.benefice, k2.benefice)}
      </div>

      {/* Graphique heures par client */}
      {chartData.length > 0 && (
        <div style={{ background:'var(--bg2)', border:'1px solid var(--border)', borderRadius:'var(--radius)', padding:'14px 16px' }} className="anim">
          <div style={{ fontSize:13, fontWeight:500, color:'var(--text2)', marginBottom:12 }}>⏱ Heures par client</div>
          <ResponsiveContainer width="100%" height={140}>
            <BarChart data={chartData} margin={{ top:0, right:0, left:-20, bottom:0 }}>
              <XAxis dataKey="name" tick={{ fill:'var(--text2)', fontSize:11 }} axisLine={false} tickLine={false} />
              <YAxis tick={{ fill:'var(--text2)', fontSize:11 }} axisLine={false} tickLine={false} />
              <Tooltip
                contentStyle={{ background:'var(--bg3)', border:'1px solid var(--border)', borderRadius:8, color:'var(--text)', fontSize:12 }}
                formatter={v => [v+'h', 'Heures']}
              />
              <Bar dataKey="heures" radius={[4,4,0,0]}>
                {chartData.map((_,i) => <Cell key={i} fill={['#1D9E75','#4a90e2','#e8a23a','#e05555'][i%4]} />)}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        </div>
      )}

      {/* Dernières tâches */}
      <div style={{ background:'var(--bg2)', border:'1px solid var(--border)', borderRadius:'var(--radius)', padding:'14px 16px' }} className="anim">
        <div style={{ fontSize:13, fontWeight:500, color:'var(--text2)', marginBottom:10 }}>🗂️ Dernières tâches</div>
        {recentTaches.map(t => (
          <div key={t.id} style={{ display:'flex', alignItems:'center', gap:12, padding:'10px 0', borderBottom:'1px solid var(--border)' }}>
            <div style={{ width:36, height:36, borderRadius:10, background:'var(--bg3)', display:'flex', alignItems:'center', justifyContent:'center', fontSize:16, flexShrink:0 }}>🗂️</div>
            <div style={{ flex:1, minWidth:0 }}>
              <div style={{ fontSize:14, fontWeight:500, whiteSpace:'nowrap', overflow:'hidden', textOverflow:'ellipsis' }}>{t.motif}</div>
              <div style={{ fontSize:12, color:'var(--text2)', marginTop:1 }}>
                {new Date(t.date).toLocaleDateString('fr-FR')} · <span style={{ color:'var(--blue)' }}>{t.clients?.societe||'—'}</span>
              </div>
            </div>
            <div style={{ textAlign:'right', flexShrink:0 }}>
              <div style={{ fontSize:14, fontWeight:600, fontFamily:'monospace' }}>{t.duree}h</div>
              <div style={{ fontSize:11, color:'var(--text2)' }}>{fmtEur(t.duree*taux)}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}

function selStyle(color) {
  return {
    background:'var(--bg3)', border:'1px solid var(--border)', borderRadius:8,
    padding:'6px 10px', color, fontSize:12, fontFamily:'inherit', cursor:'pointer', outline:'none'
  }
}
